# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://CTSE:Malee123@cluster0.b1uvqpy.mongodb.net/order-service?retryWrites=true&w=majority

# JWT Secret (Must match User Service)
JWT_SECRET=your-shared-jwt-secret-key

# Internal API Key (Shared across all services)
INTERNAL_API_KEY=your-shared-internal-api-key

# User Service URL
USER_SERVICE_URL=http://localhost:3001

# Product Service URL
PRODUCT_SERVICE_URL=http://localhost:3002

# AWS SQS Configuration (for notifications)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
SQS_QUEUE_URL=dummy

# Allowed Origins (CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001