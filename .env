# Server Configuration
PORT=3002
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=order_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT Secret (Must match User Service)
JWT_SECRET=your-shared-jwt-secret-key

# Internal API Key (Shared across all services)
INTERNAL_API_KEY=your-shared-internal-api-key

# User Service URL
USER_SERVICE_URL=http://localhost:3003

# Product Service URL
PRODUCT_SERVICE_URL=http://localhost:3004

# AWS SQS Configuration (for notifications)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
SQS_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/599657397559/order-events-queue

# Allowed Origins (CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
